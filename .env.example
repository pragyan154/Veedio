# ============================================================
# NewPick Video Pipeline — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# ---------- Google Gemini API Key (REQUIRED) ----------
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---------- Google Cloud Speech-to-Text ----------
# Service account JSON lives at: app/scibugai-0c6edfa92c76.json
# (auto-detected by Transcribe.py, no env var needed)

# ---------- OpenRouter API Key (OPTIONAL) ----------
# Only needed if ai_provider is set to "openrouter" in app/config.json
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ---------- Video Pipeline Settings (OPTIONAL) ----------
# Override via env or leave defaults from config.json

# Video orientation: "vertical" (1080x1350) or "horizontal" (1920x1080)
# VIDEO_ORIENTATION=vertical

# Template theme: "pg" or "failaan"
# VIDEO_TEMPLATE_THEME=pg

# Language: "hindi" or "hinglish"
# LANGUAGE=hindi
